#!/usr/bin/env sh
set -eu

ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
ORIGINAL_CWD="$(pwd)"
NORMALIZED_ARGS=""
while [ "$#" -gt 0 ]; do
  case "$1" in
    --project|--foundation-root)
      key="$1"
      shift
      value="$1"
      case "$value" in
        /*) ;;
        [A-Za-z]:/*|[A-Za-z]:\\*) ;;
        *) value="$ORIGINAL_CWD/$value" ;;
      esac
      NORMALIZED_ARGS="$NORMALIZED_ARGS \"$key\" \"$value\""
      ;;
    --project=*|--foundation-root=*)
      key="${1%%=*}"
      value="${1#*=}"
      case "$value" in
        /*) ;;
        [A-Za-z]:/*|[A-Za-z]:\\*) ;;
        *) value="$ORIGINAL_CWD/$value" ;;
      esac
      NORMALIZED_ARGS="$NORMALIZED_ARGS \"$key=$value\""
      ;;
    *)
      NORMALIZED_ARGS="$NORMALIZED_ARGS \"$1\""
      ;;
  esac
  shift
done
if [ -n "${PYTHONPATH:-}" ]; then
  export PYTHONPATH="$ROOT/engine:$PYTHONPATH"
else
  export PYTHONPATH="$ROOT/engine"
fi

if command -v uv >/dev/null 2>&1; then
  cd "$ROOT"
  eval "exec uv run python -m codex_pipeline.cli $NORMALIZED_ARGS"
fi

if command -v python3 >/dev/null 2>&1; then
  eval "exec python3 -m codex_pipeline.cli $NORMALIZED_ARGS"
fi

eval "exec python -m codex_pipeline.cli $NORMALIZED_ARGS"
